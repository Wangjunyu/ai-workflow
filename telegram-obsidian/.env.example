# Telegram Bot Token - 从 @BotFather 获取
TELEGRAM_BOT_TOKEN=your_bot_token_here

# 允许使用 bot 的 Telegram user ID，逗号分隔；必填
# 同一个用户在不同机器部署时通常保持相同 Telegram user ID，无需按机器分别登记
ALLOWED_USERS=123456789

# 本地 Obsidian git 仓库路径
OBSIDIAN_REPO_PATH=/Users/leon-home/leon-obsidian

# Journal 目录（相对于仓库根目录）
JOURNAL_DIR=Journal

# 日记文件命名格式
JOURNAL_FORMAT=%Y-%m-%d

# INBOX 标题
INBOX_HEADER=## INBOX

# 时区
TIMEZONE=Asia/Shanghai

# git commit message 前缀
COMMIT_PREFIX=telegram-journal

# 目标分支名；如果不同机器都同步同一个 Obsidian 仓库，请保持一致
GIT_BRANCH=main
